# MiniMax 代理配置
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_API_URL=https://mini.niagaradataanalyst.com/v1
MINIMAX_PROXY_TOKEN=your-proxy-token
# 可选，默认 MiniMax-M2.7
MINIMAX_MODEL_ID=MiniMax-M2.7

# Resend 邮件服务（可选；未设置时联系表单降级为日志）
# 注册 https://resend.com 免费获取 API Key（3000 封/月）
RESEND_API_KEY=re_xxxxxxxxx
# 发件人：无自定义域名时保持 onboarding@resend.dev 即可
CONTACT_FROM_EMAIL=NiagaraDataAnalyst <onboarding@resend.dev>
CONTACT_TO_EMAIL=jonzy.xin@outlook.com

# 网站配置
NEXT_PUBLIC_SITE_URL=https://niagaradataanalyst.com

# Google Search Console 验证码
GOOGLE_SITE_VERIFICATION=your-verification-code
